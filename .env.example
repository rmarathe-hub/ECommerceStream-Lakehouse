# Copy to .env and fill in values as needed throughout the project.
# cp .env.example .env

# --- Local stack (Week 1) ---
# Host clients (Python producer on laptop) use the external listener:
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
# Spark jobs running inside Docker use the internal listener:
KAFKA_BOOTSTRAP_SERVERS_DOCKER=redpanda:9092
KAFKA_TOPIC=ecommerce_events

SPARK_MASTER_URL=spark://localhost:7077
SPARK_MASTER_URL_DOCKER=spark://spark-master:7077

MINIO_ENDPOINT=localhost:9000
MINIO_ENDPOINT_DOCKER=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=commercestream-lake

# --- AWS (Week 3) ---
# Use dedicated upload user credentials after Day 20 terraform apply — never commit .env
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=commercestream-lake-YOUR-NAME-us-east-1
AWS_S3_GOLD_PREFIX=gold

# --- Snowflake (Week 4+) — target budget $2–6/month, hard cap $6 ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_DATABASE=COMMERCESTREAM_DB
SNOWFLAKE_WAREHOUSE=DE_PROJECT_WH
SNOWFLAKE_SCHEMA=MARTS

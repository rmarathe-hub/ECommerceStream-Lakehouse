# Copy to terraform.tfvars (gitignored) and adjust for your account.
# cp terraform.tfvars.example terraform.tfvars
#
# Do not commit terraform.tfvars — it may contain account-specific names.

region       = "us-east-1"
bucket_name  = "commercestream-lake-YOUR-NAME-us-east-1"
project_name = "ECommerceStream-Lakehouse"
environment  = "dev"

# Dedicated upload user (Option A — least privilege)
create_upload_user       = true
upload_user_name         = "commercestream-lakehouse-uploader"
create_upload_access_key = true

# S3 lifecycle expiration (days) — gold/ is never expired
lifecycle_temp_expiration_days          = 1
lifecycle_checkpoints_expiration_days   = 7
lifecycle_bronze_sample_expiration_days = 30

# AWS monthly cost budget (requires email for notifications to be created)
create_budget_alert      = true
budget_monthly_limit_usd = 5
budget_alert_emails      = ["your-email@example.com"]
budget_alert_thresholds  = [50, 80, 100]
